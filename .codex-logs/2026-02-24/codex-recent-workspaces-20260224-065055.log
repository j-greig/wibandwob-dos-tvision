+static std::vector<std::string> scanRecentWorkspacePaths(const char* dirPath, int maxCount)
+{
+    std::vector<RecentWorkspaceInfo> entries;
+    DIR* dir = opendir(dirPath);
+    if (!dir)
+        return {};
+
+    struct dirent* ent;
