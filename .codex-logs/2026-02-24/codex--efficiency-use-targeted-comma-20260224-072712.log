#"'!/usr/bin/env bash
set -euo pipefail
EX=(--glob '"'"'!.git/**'"' --glob '"'!build/**'"' --glob '"'!build-linux/**'"' --glob '"'!.venv/**'"' --glob '"'!partykit/node_modules/**'"' --glob '"'!.pytest_cache/**'"' --glob '"'!.codex-logs/**'"' --glob '"'!archive/**'"' --glob '"'!docs/codex-reviews/**'"' --glob '"'!.planning/audits/.trash/**'"' --glob '"'!memories/**'"')

report() {
  local title=\""'$1" pattern="$2"; shift 2
  echo "## $title"
  local files
  files=$(rg -l --hidden "${EX[@]}" "$pattern" "$@" 2>/dev/null || true)
  local file_count=0
  if [[ -n "$files" ]]; then file_count=$(printf '"'%s\\n' \""'$files" | wc -l | tr -d '"' '); fi
  local match_count
  match_count="'$(rg -o --hidden "${EX[@]}" "$pattern" "$@" 2>/dev/null | wc -l | tr -d '"' ' || true)
  echo \"files="'$file_count matches=$match_count"
  if [[ -n "$files" ]]; then printf '"'%s\\n' \""'$files" | sort; fi
  echo
}

