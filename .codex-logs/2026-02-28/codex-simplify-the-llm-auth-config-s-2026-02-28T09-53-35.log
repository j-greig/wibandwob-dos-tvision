+bool LLMConfig::parseJson(const std::string& jsonConfig) {
+    try {
+        const json root = json::parse(jsonConfig);
+
+        providers.clear();
+        activeProvider = root.value("activeProvider", "claude_code_sdk");
+
+        if (!root.contains("providers") || !root["providers"].is_object()) {
+            validationErrors.push_back("No providers section found in config");
+            return false;
+        }
+
+        for (auto it = root["providers"].begin(); it != root["providers"].end(); ++it) {
+            if (!it.value().is_object()) {
+                continue;
+            }
+
+            ProviderConfig config;
+            const json& providerJson = it.value();
+
+            config.enabled = providerJson.value("enabled", true);
+            config.model = providerJson.value("model", "");
+            config.endpoint = providerJson.value("endpoint", "");
+            config.apiKeyEnv = providerJson.value("apiKeyEnv", "");
+            config.command = providerJson.value("command", "");
+
+            if (providerJson.contains("args") && providerJson["args"].is_array()) {
+                for (const auto& arg : providerJson["args"]) {
+                    if (arg.is_string()) {
+                        config.args.push_back(arg.get<std::string>());
+                    }
+                }
+            }
+
+            if (providerJson.contains("allowedTools") && providerJson["allowedTools"].is_array()) {
+                for (const auto& tool : providerJson["allowedTools"]) {
+                    if (tool.is_string()) {
+                        config.allowedTools.push_back(tool.get<std::string>());
+                    }
+                }
+            }
+
+            for (auto field = providerJson.begin(); field != providerJson.end(); ++field) {
+                const std::string& key = field.key();
+                if (key == "enabled" || key == "model" || key == "endpoint" ||
+                    key == "apiKeyEnv" || key == "command" || key == "args" ||
+                    key == "allowedTools") {
+                    continue;
+                }
+
+                config.parameters[key] = jsonValueToString(field.value());
+            }
+
+            providers[it.key()] = config;
+        }
+
+        validateConfiguration();
+        return validationErrors.empty();
+    } catch (const json::exception& e) {
+        validationErrors.push_back(std::string("Invalid config JSON: ") + e.what());
+        return false;
+    }
+}
+
+std::string LLMConfig::generateJson() const {
+    json root;
+    root["activeProvider"] = activeProvider;
+    root["providers"] = json::object();
+
+    for (const auto& pair : providers) {
+        const std::string& name = pair.first;
+        const ProviderConfig& config = pair.second;
+        json providerJson;
+
+        providerJson["enabled"] = config.enabled;
+
+        if (!config.model.empty()) {
+            providerJson["model"] = config.model;
+        }
+        if (!config.endpoint.empty()) {
+            providerJson["endpoint"] = config.endpoint;
+        }
+        if (!config.apiKeyEnv.empty()) {
+            providerJson["apiKeyEnv"] = config.apiKeyEnv;
+        }
+        if (!config.command.empty()) {
+            providerJson["command"] = config.command;
+        }
+        if (!config.args.empty()) {
+            providerJson["args"] = config.args;
+        }
+        if (!config.allowedTools.empty()) {
+            providerJson["allowedTools"] = config.allowedTools;
+        }
+
+        for (const auto& param : config.parameters) {
+            providerJson[param.first] = param.second;
+        }
+
