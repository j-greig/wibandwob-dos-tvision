+## Full Coordinator Script (Phase 3 + Phase 4)
+
+Create file: `tools/monitor/chat_coordinator.py`
+
+This script intentionally uses:
+
+- socket discovery pattern from `tools/monitor/instance_monitor.py`
+- IPC wire format pattern from `tools/api_server/ipc_client.py`
+- percent-encoding for `text=` (not base64), because `exec_command` params are only percent-decoded generically in `app/api_ipc.cpp`
+
+```python
+#!/usr/bin/env python3
+"""Relay assistant messages between multiple local WibWob-DOS instances via IPC.
+
+Option A only: local Unix sockets (/tmp/wibwob_*.sock).
+"""
+
+from __future__ import annotations
+
+import argparse
+import glob
+import json
+import math
+import os
+import socket
+import sys
+import time
+from typing import Dict, List
+
+
+def discover_sockets() -> List[str]:
+    """Find all /tmp/wibwob_*.sock files plus legacy path."""
+    socks = sorted(glob.glob("/tmp/wibwob_*.sock"))
+    legacy = "/tmp/test_pattern_app.sock"
+    if os.path.exists(legacy) and legacy not in socks:
+        socks.insert(0, legacy)
+    return socks
+
+
+def instance_name(sock_path: str) -> str:
+    return os.path.basename(sock_path).replace(".sock", "")
+
+
+def pct_encode(value: str) -> str:
+    # Match C++ percent_decode() support in app/api_ipc.cpp.
+    return (
+        value.replace("%", "%25")
+        .replace(" ", "%20")
+        .replace("\n", "%0A")
+        .replace("\r", "%0D")
+        .replace("\t", "%09")
+    )
+
+
+def send_ipc_line(sock_path: str, line: str, timeout: float = 5.0) -> str:
+    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
+    s.settimeout(timeout)
+    s.connect(sock_path)
+    try:
+        s.sendall((line.rstrip("\n") + "\n").encode("utf-8"))
+        chunks: List[bytes] = []
+        while True:
+            chunk = s.recv(8192)
+            if not chunk:
+                break
+            chunks.append(chunk)
+        return b"".join(chunks).decode("utf-8", errors="ignore").strip()
+    finally:
+        s.close()
+
+
+def exec_command(sock_path: str, name: str, **kv: str) -> str:
+    parts = [f"cmd:exec_command", f"name={name}"]
+    for k, v in kv.items():
+        parts.append(f"{k}={pct_encode(str(v))}")
+    return send_ipc_line(sock_path, " ".join(parts))
+
+
+def get_chat_history(sock_path: str) -> List[dict]:
+    raw = exec_command(sock_path, "get_chat_history")
+    if raw.startswith("err"):
+        raise RuntimeError(raw)
+    data = json.loads(raw)
+    msgs = data.get("messages", [])
+    if not isinstance(msgs, list):
+        raise RuntimeError("invalid get_chat_history payload: messages is not a list")
+    return msgs
+
+
+def estimate_tokens(text: str) -> int:
+    # Cheap budget proxy (4 chars/token heuristic)
+    return max(1, math.ceil(len(text) / 4))
+
+
+def relay_to_peer(target_sock: str, source_label: str, content: str) -> str:
+    prefixed = f"[{source_label}] {content}"
+    # Use wibwob_ask so the receiving instance treats it as user input and responds.
+    return exec_command(target_sock, "wibwob_ask", text=prefixed)
+
+
+def parse_args() -> argparse.Namespace:
+    p = argparse.ArgumentParser(description="Relay assistant messages between WibWob instances")
+    p.add_argument("--poll-interval", type=float, default=2.0, help="Seconds between polls (default: 2.0)")
+    p.add_argument("--max-turns", type=int, default=20, help="Max relayed assistant messages before stopping")
+    p.add_argument("--cooldown", type=float, default=5.0, help="Min seconds between relays to same target")
+    p.add_argument("--token-budget", type=int, default=4000, help="Approx token budget before stop")
+    p.add_argument("--require", type=int, default=2, help="Minimum live instances required (default: 2)")
+    return p.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+
+    last_seen_counts: Dict[str, int] = {}
+    last_relay_to_target_at: Dict[str, float] = {}
+    relayed_turns = 0
+    token_spend_est = 0
+
+    print(
+        f"[coordinator] start poll={args.poll_interval}s max_turns={args.max_turns} "
+        f"cooldown={args.cooldown}s token_budget={args.token_budget}"
+    )
+
+    try:
+        while True:
+            socks = discover_sockets()
+            if len(socks) < args.require:
+                print(f"[coordinator] waiting for >= {args.require} sockets; found {len(socks)}")
+                time.sleep(args.poll_interval)
+                continue
+
+            # Initialize cursors for new sockets.
+            for sp in socks:
+                last_seen_counts.setdefault(sp, 0)
+
+            # Drop cursors for dead sockets (if removed while running).
+            dead = [sp for sp in list(last_seen_counts.keys()) if sp not in socks]
+            for sp in dead:
+                print(f"[coordinator] socket disappeared: {sp}")
+                last_seen_counts.pop(sp, None)
+                last_relay_to_target_at.pop(sp, None)
+
+            for source_sock in socks:
+                source_label = instance_name(source_sock)
+                try:
+                    msgs = get_chat_history(source_sock)
+                except Exception as e:
+                    print(f"[coordinator] read fail {source_label}: {e}")
+                    continue
+
+                prev = last_seen_counts.get(source_sock, 0)
+                if len(msgs) < prev:
+                    # Chat was cleared/reset; restart cursor.
+                    print(f"[coordinator] history reset detected on {source_label} ({prev} -> {len(msgs)})")
+                    prev = 0
+
+                new_msgs = msgs[prev:]
+                last_seen_counts[source_sock] = len(msgs)
+
+                if not new_msgs:
+                    continue
+
+                for msg in new_msgs:
+                    role = str(msg.get("role", ""))
+                    content = str(msg.get("content", ""))
+                    if role != "assistant":
+                        continue
+                    if not content.strip():
+                        continue
+
+                    for target_sock in socks:
+                        if target_sock == source_sock:
+                            continue
+
+                        target_label = instance_name(target_sock)
+                        now = time.time()
+                        last_at = last_relay_to_target_at.get(target_sock, 0.0)
+                        if args.cooldown > 0 and (now - last_at) < args.cooldown:
+                            print(
+                                f"[coordinator] cooldown skip {source_label}->{target_label} "
+                                f"({now - last_at:.1f}s < {args.cooldown:.1f}s)"
+                            )
+                            continue
+
+                        est = estimate_tokens(content)
+                        if token_spend_est + est > args.token_budget:
+                            print(
+                                f"[coordinator] token budget reached: {token_spend_est}+{est} > {args.token_budget}"
+                            )
+                            return 0
+
+                        try:
+                            resp = relay_to_peer(target_sock, source_label, content)
+                        except Exception as e:
+                            print(f"[coordinator] relay fail {source_label}->{target_label}: {e}")
+                            continue
+
+                        if resp.startswith("err"):
+                            print(f"[coordinator] relay rejected {source_label}->{target_label}: {resp}")
+                            continue
+
+                        token_spend_est += est
+                        relayed_turns += 1
+                        last_relay_to_target_at[target_sock] = now
+                        print(
+                            f"[coordinator] relay #{relayed_turns}: {source_label}->{target_label} "
+                            f"chars={len(content)} est_tokens={est} budget_used={token_spend_est}/{args.token_budget} "
+                            f"resp={resp}"
+                        )
+
+                        if relayed_turns >= args.max_turns:
+                            print(f"[coordinator] max turns reached ({args.max_turns}); stopping")
+                            return 0
+
+            time.sleep(args.poll_interval)
+
+    except KeyboardInterrupt:
+        print("\n[coordinator] stopped by user")
+        return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
+```
+
+## Why the Coordinator Uses Percent-Encoding (Not Base64 for `text=`)
+
+This is the most likely implementation footgun.
+
+- `tools/api_server/ipc_client.py` base64-encodes only the `content` field (`tools/api_server/ipc_client.py:58-67`)
+- The generic `exec_command` parser in C++ percent-decodes all `k=v` values (`app/api_ipc.cpp:379-392`)
+- Base64 decoding is only applied in the `send_text` handler for `content` (`app/api_ipc.cpp:505-517`)
+
+Therefore:
+
+- `cmd:exec_command name=wibwob_ask text=hello%20world` works
+- `cmd:exec_command name=wibwob_ask text=base64:aGVsbG8gd29ybGQ=` will currently pass the literal `base64:...` string to the chat unless you add new C++ decoding logic (out of scope for this spike)
+
+## Step-by-Step Implementation Plan (One Pass)
+
+1. Patch `app/wibwob_view.h` to add history types, storage, and `getHistoryJson()`
+2. Patch `app/wibwob_view.cpp` to:
+   - add JSON escape helper
+   - record history in `addMessage`
+   - clear history in `clear`
+   - mirror streaming lifecycle into `chatHistory_`
+   - implement `getHistoryJson()`
+3. Patch `app/test_pattern_app.cpp` to add `api_get_chat_history(TTestPatternApp&)`
+4. Patch `app/command_registry.cpp` to add:
+   - extern
+   - capability
+   - dispatch branch
+5. Add `tools/monitor/chat_coordinator.py` (script above)
+6. Build + verify phase-by-phase (commands below)
+
