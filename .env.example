# WibWob-DOS environment variables
# Copy to .env and fill in values. Never commit .env itself.

# OpenRouter API key — free tier works with openrouter/free model
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic API key — optional, overrides OpenRouter when set via Help > Set API Key
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# PartyKit room chat (Sprites hosting)
WIBWOB_PARTYKIT_URL=wss://wibwob-rooms.j-greig.partykit.dev
WIBWOB_PARTYKIT_ROOM=rchat-live

# App root (usually auto-detected)
# APP=/home/sprite/app
