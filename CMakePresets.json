{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-${presetName}"
    },
    {
      "name": "dev",
      "displayName": "Dev (Debug)",
      "description": "Default local dev build — debug symbols, fast rebuild. Uses ./build/ (existing convention).",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "sprites",
      "displayName": "Sprites (Release, Linux)",
      "description": "Production build for Sprites.dev hosting. Release optimisations, stripped binary, separate build dir.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXE_LINKER_FLAGS": "-s"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "release",
      "displayName": "Release (cross-platform)",
      "description": "Release build without strip flag — works on macOS and Linux.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "displayName": "Build dev",
      "configurePreset": "dev",
      "targets": ["wwdos"]
    },
    {
      "name": "sprites",
      "displayName": "Build sprites (Linux)",
      "configurePreset": "sprites",
      "targets": ["wwdos"]
    },
    {
      "name": "release",
      "displayName": "Build release",
      "configurePreset": "release",
      "targets": ["wwdos"]
    }
  ]
}
