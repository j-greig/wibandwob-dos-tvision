static TRect calcStampDialogBounds() {
    TRect d = TProgram::deskTop->getExtent();
    int dw = d.b.x - d.a.x;
    int dh = d.b.y - d.a.y;
    int w = std::max(60, (int)(dw * 0.85));
    int h = std::max(18, (int)(dh * 0.85));
    int left = d.a.x + (dw - w) / 2;
    int top  = d.a.y + (dh - h) / 2;
    return TRect(left, top, left + w, top + h);
}

