def composite(layers):
    rh, rw = len(layers[0]), len(layers[0][0])
    canvas = [[' ']*rw for _ in range(rh)]
    for layer in layers:
        for y in range(rh):
            for x in range(rw):
                if layer[y][x] != ' ':
                    canvas[y][x] = layer[y][x]
    return canvas


