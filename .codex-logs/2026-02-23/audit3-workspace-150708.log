**Planning per-file count output**

I'm preparing a bash script to produce structured count tables per file for easy parsing and manual summarization.
exec
bash -lc 'for file in workspaces/*.json; do
  echo "FILE:$file";
  echo "TYPES:";
  declare -A counts=();
  while IFS= read -r type; do
    if [ -n "$type" ]; then
      counts[$type]=$((counts[$type]+1));
    fi
  done < <(rg -o '"'\"type\"[[:space:]]*:[[:space:]]*\"["'^"]+"'"' \""'$file" | sed -E '"'s/.*\"type\"[[:space:]]*:[[:space:]]*\"(["'^"]+)".*/'"\\1/')
  for key in \""'${!counts[@]}"; do
    echo "$key=${counts[$key]}";
  done
  echo "EMPTY_PROPS:"; rg -c '"'\"props\"[[:space:]]*:[[:space:]]*\\{[[:space:]]*\\}' \""'$file";
  echo "EMPTY_TITLES:"; rg -c '"'\"title\"[[:space:]]*:[[:space:]]*\"\"' \""'$file";
  echo "FRAME_PLAYER_KEYS:";
  declare -A fpkeys=();
  while IFS= read -r block; do
    while IFS= read -r key; do
      key_clean=$(echo "$key" | sed -E '"'s/\"(["'^"]+)".*/'"\\1/');
      if [ -n \""'$key_clean" ]; then
        fpkeys[$key_clean]=1;
      fi
    done < <(echo "$block" | rg -o '"'\"["'^"]+"[[:space:]]*:'"' )
  done < <(rg --multiline --multiline-dotall '\"type\"[[:space:]]*:[[:space:]]*\"frame_player\"[\\s\\S]*?\"props\"[[:space:]]*:[[:space:]]*\\{["'^}]*'"\\}' \""'$file")
  for key in "${!fpkeys[@]}"; do
    echo "$key";
  done
  echo "---";
