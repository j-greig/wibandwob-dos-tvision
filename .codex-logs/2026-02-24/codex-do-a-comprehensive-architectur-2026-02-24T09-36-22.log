template <typename ViewType>
static bool has_child_view(TWindow* w) {
    if (!w) return false;
    TView* start = w->first();
    if (!start) return false;
    TView* v = start;
    do {
        if (dynamic_cast<ViewType*>(v)) return true;
        v = v->next;
    } while (v != start);
    return false;
}

